#include <stdio.h>
#include <ctype.h>
#include <string.h>

void monoalphabeticEncrypt(char message[]) {
    char plain[] = "abcdefghijklmnopqrstuvwxyz";
    char cipher[] = "qwertyuiopasdfghjklzxcvbnm";

    for (int i = 0; message[i] != '\0'; i++) {
        char ch = message[i];

        if (isupper(ch)) {
            char lower = tolower(ch);
            for (int j = 0; plain[j] != '\0'; j++) {
                if (lower == plain[j]) {
                    message[i] = toupper(cipher[j]);
                    break;
                }
            }
        } else if (islower(ch)) {
            for (int j = 0; plain[j] != '\0'; j++) {
                if (ch == plain[j]) {
                    message[i] = cipher[j];
                    break;
                }
            }
        }
    }
}

int main() {
    char message[200];

    printf("Enter the message: ");
    fgets(message, sizeof(message), stdin);

    monoalphabeticEncrypt(message);

    printf("Encrypted message: %s\n", message);
    return 0;
}
