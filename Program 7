static int countChar(const char *text, char ch) {
    int count = 0;
    for (int i = 0; text[i] != '\0'; i++) {
        if (text[i] == ch) count++;
    }
    return count;
}

static void replaceAll(char *text, char from, char to) {
    for (int i = 0; text[i] != '\0'; i++) {
        if (text[i] == from) text[i] = to;
    }
}

