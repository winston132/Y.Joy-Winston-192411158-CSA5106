#include <stdio.h>
#include <ctype.h>

void caesarEncrypt(char message[], int key) {
    for (int i = 0; message[i] != '\0'; i++) {
        char ch = message[i];

        if (isupper(ch)) {
            message[i] = ((ch - 'A' + key) % 26) + 'A';
        } else if (islower(ch)) {
            message[i] = ((ch - 'a' + key) % 26) + 'a';
        }
    }
}

int main() {
    char message[200];
    int key;

    printf("Enter the message: ");
    fgets(message, sizeof(message), stdin);

    do {
        printf("Enter key value (1-25): ");
        scanf("%d", &key);
    } while (key < 1 || key > 25);

    caesarEncrypt(message, key);

    printf("Encrypted message: %s\n", message);
    return 0;
}
